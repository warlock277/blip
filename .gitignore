# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
*.tsbuildinfo
packages/dashboard/dist/

# env / secrets — NEVER commit these
.env
.env.local
.env.*.local
*.secret

# your real config — may contain private hostnames/IPs. Ship the example instead.
# (config/blip.config.example.yaml is tracked; the engine falls back to it.)
/blip.config.yaml
/blip.config.yaml.bak

# logs
*.log
npm-debug.log*
.npm/

# editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# test / coverage
coverage/
.nyc_output/

# local scratch
.cache/
tmp/

# generated by `npm run seed` for local preview only (the dashboard ships its
# own demo data in packages/dashboard/public/data/; the Worker uses D1).
/data/
